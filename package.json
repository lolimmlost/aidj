{
  "name": "aidj-music-interface",
  "version": "1.0.0",
  "description": "AIDJ Music Library Interface - Modern music streaming and library management application",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3003 --host",
    "build": "vite build",
    "build:cloudflare": "DEPLOY_TARGET=cloudflare vite build",
    "start": "tsx --env-file=.env server.ts",
    "start:prod": "npm run build && tsx --env-file=.env server.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "start:frontend": "vite dev --port 3000",
    "start:backend": "tsx --env-file=.env server.ts",
    "check-types": "tsc --noEmit",
    "check": "npm format && npm lint && npm check-types",
    "db": "drizzle-kit",
    "db:studio": "drizzle-kit studio",
    "deps": "npm dlx taze@latest -Ilw",
    "deps:major": "npm dlx taze@latest major -Ilw",
    "ui": "npm dlx shadcn@latest",
    "auth:secret": "npm dlx @better-auth/cli@latest secret",
    "auth:generate": "npm dlx @better-auth/cli@latest generate --config ./src/lib/auth/auth.ts --y --output ./src/lib/db/schema/auth.schema.ts && prettier --write ./src/lib/db/schema/auth.schema.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "e2e": "playwright test",
    "test:ci:e2e": "playwright test tests/e2e/ --headed=false --coverage --reporter=html,line,json --project=e2e",
    "deploy": "npm run build:cloudflare && wrangler pages deploy .output/public",
    "deploy:production": "npm run build:cloudflare && wrangler pages deploy .output/public --branch=main",
    "deploy:preview": "npm run build:cloudflare && wrangler pages deploy .output/public --branch=preview",
    "readme:screenshots": "npx tsx scripts/capture-readme-screenshots.ts",
    "readme:update": "npx tsx scripts/update-readme-with-screenshots.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-email/components": "^1.0.10",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-devtools": "^0.5.4",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/react-virtual": "^3.13.13",
    "@vitejs/plugin-react": "^5.0.2",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "drizzle-orm": "^0.44.5",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.542.0",
    "postgres": "^3.4.8",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.2",
    "react-dom": "^19.2.4",
    "recharts": "^3.3.0",
    "resend": "^6.10.0",
    "sirv": "^3.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "use-sync-external-store": "^1.2.2",
    "vite": "^7.1.3",
    "ws": "^8.20.0",
    "zod": "^4.1.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^1.52.8",
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/devtools-vite": "^0.2.10",
    "@tanstack/eslint-plugin-query": "^5.83.1",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie": "^1.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "^2.1.9",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "6.0.0-rc.2",
    "jsdom": "^23.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.3"
  }
}
